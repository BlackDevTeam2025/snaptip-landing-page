SHOPIFY_API_SECRET=your_shopify_app_secret
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_VERSION=2026-04
SHOPIFY_SCOPES=read_orders,read_publications,write_cart_transforms,write_products,write_publications
APP_BASE_URL=https://snaptip.tech
SHOPIFY_EMBEDDED_APP_URL=https://app.snaptip.tech
INTERNAL_SYNC_SECRET=replace_me_with_a_long_random_secret

ADMIN_EMAIL=admin@snaptip.tech
ADMIN_PASSWORD=ChangeMe12345!
ADMIN_ROLE=owner
ADMIN_SESSION_TTL_SECONDS=604800

POSTGRES_URL=postgresql://user:password@host/db?sslmode=require
