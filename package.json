{
  "name": "snaptip-landing-page",
  "version": "1.0.0",
  "private": true,
  "description": "SnapTip landing + webhook backend + admin dashboard for Vercel",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:admin\"",
    "dev:api": "node api/index.js",
    "dev:admin": "vite",
    "test:seed-tip": "node scripts/seed-tip.js",
    "build": "npm run build:admin && npm run build:dist",
    "build:admin": "vite build",
    "build:dist": "node scripts/build-dist.js",
    "preview:admin": "vite preview",
    "lint": "eslint \"api/**/*.js\" \"apps/admin/src/**/*.{js,jsx}\" \"*.{js,cjs,mjs}\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.72.2",
    "@vercel/postgres": "^0.10.0",
    "express": "^4.21.2",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
