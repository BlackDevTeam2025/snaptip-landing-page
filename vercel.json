{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin-api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/app/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/:path((?!.*\\..*).*)",
      "destination": "/admin/index.html"
    }
  ]
}
